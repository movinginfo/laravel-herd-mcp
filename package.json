{
  "name": "laravel-herd-mcp",
  "version": "0.1.31",
  "description": "218 MCP tools for full Laravel Herd control — sites, PHP, SSL, Pulse, Telescope, Nightwatch, Forge CLI and more. Works on Windows and macOS.",
  "main": "dist/index.js",
  "bin": {
    "laravel-herd-mcp": "dist/index.js",
    "herd-mcp": "dist/index.js"
  },
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "laravel",
    "herd",
    "claude",
    "windows",
    "macos",
    "vscode",
    "cursor",
    "telescope",
    "pulse",
    "nightwatch",
    "forge",
    "artisan"
  ],
  "author": "laravel-herd-mcp contributors",
  "homepage": "https://github.com/movinginfo/laravel-herd-mcp#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/movinginfo/laravel-herd-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/movinginfo/laravel-herd-mcp/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.18.0",
    "mysql2": "^3.20.0",
    "pg": "^8.20.0",
    "strip-ansi": "^7.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.8.0"
  }
}
